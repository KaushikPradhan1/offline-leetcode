{
  "name": "offline-leetcode",
  "displayName": "Offline LeetCode",
  "description": "Solve LeetCode problems completely offline inside VS Code.",
  "version": "1.0.0",
  "publisher": "Kaushik",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaushikpradhan1/offline-leetcode"
  },
  "icon": "media/icon.png",
  "keywords": [
    "leetcode",
    "offline",
    "dsa",
    "competitive-programming"
  ],
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Education"
  ],
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "offlineLeetcodeContainer",
          "title": "Offline LeetCode",
          "icon": "$(code)"
        }
      ]
    },
    "views": {
      "offlineLeetcodeContainer": [
        {
          "id": "offlineLeetcodeView",
          "name": "Questions"
        }
      ]
    },
    "commands": [
      {
        "command": "offlineLeetcode.openProblem",
        "title": "Open Problem"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.80.0",
    "eslint": "^9.0.0"
  }
}
